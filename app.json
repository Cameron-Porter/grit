{
  "expo": {
    "name": "GRIT",
    "slug": "grit",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "grit",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon",
      "bundleIdentifier": "com.gritfitness.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.gritfitness.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#000000",
        "foregroundImage": "./assets/images/android-icon-foreground.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#111114",
          "android": {
            "image": "./assets/images/icon.png",
            "imageWidth": 160
          }
        }
      ],
      "expo-image",
      "expo-sharing",
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "grit-hypertrophy-app",
          "organization": "grit-7z"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ce3eb619-a8b7-47f9-a921-4cfb692d3f39"
      }
    }
  }
}
